# ==========================================
# AUTH SERVICE CONFIGURATION
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==========================================

# === SERVICE PORTS ===
# Ports exposed on the host for each service
GAME_SERVICE_PORT=3000
AUTH_SERVICE_PORT=8001
AUTH_SERVICE_INTERNAL_PORT=8000
FRONTEND_PROD_HTTPS_PORT=4443
POSTGRES_EXTERNAL_PORT=5433

# === DATABASE CONFIGURATION ===
# PostgreSQL credentials for auth-service
POSTGRES_USER=transcendence_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=transcendence_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === SECURITY ===
# Generate a strong secret key with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here_minimum_32_characters_long

# API Key for public API access
API_KEY=aa300c08363cf50043a8ddc68fc528f6c44754040377c0b86e888281f6e411ea

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === API CONFIGURATION ===
API_V1_STR=/api/v1
PROJECT_NAME=Auth Service - ft_transcendence
VERSION=1.0.0

# === CORS ORIGINS ===
# Comma-separated list of allowed origins
# Example: https://localhost:3000,https://localhost:8080
BACKEND_CORS_ORIGINS=https://localhost:3000,https://localhost:8080
